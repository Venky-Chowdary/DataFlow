{
  "name": "dataflow",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/design-system"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@dataflow/web",
    "dev:api": "cd apps/api && uvicorn main:app --reload --port 8000",
    "build": "npm run build --workspace=@dataflow/web",
    "storybook": "npm run storybook --workspace=@dataflow/design-system",
    "test": "npm run test:api && npm run test:preflight",
    "test:preflight": "cd packages/preflight && python -m pytest tests -v",
    "test:api": "cd apps/api && python -m pytest tests -v",
    "generate:catalog": "cd apps/api && python scripts/generate_connector_catalog.py",
    "generate:training": "cd packages/ml/src/ml/synthetic && python factory.py --count 10000"
  }
}
