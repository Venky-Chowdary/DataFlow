# DataFlow Web — Railway (static UI, API on separate Railway service)
FROM node:20-alpine AS build

WORKDIR /app
COPY package.json package-lock.json* ./
COPY apps/web/package.json apps/web/
COPY packages/design-system/package.json packages/design-system/
COPY packages/design-system packages/design-system
COPY apps/web apps/web

RUN npm ci --workspace=@dataflow/web 2>/dev/null || npm install --workspace=@dataflow/web

# Set in Railway → Web service → Variables (or build ARG):
# VITE_API_BASE=https://YOUR-API-SERVICE.up.railway.app/api/v1
# Or set DATAFLOW_API_BASE at runtime to override without rebuilding.
ARG VITE_API_BASE=/api/v1
ENV VITE_API_BASE=$VITE_API_BASE

RUN npm run build --workspace=@dataflow/web

FROM nginx:1.27-alpine

ENV PORT=80
EXPOSE 80

COPY deploy/nginx.conf.template /etc/nginx/conf.d/default.conf
COPY deploy/start-nginx.sh /app/start-nginx.sh
RUN chmod +x /app/start-nginx.sh

COPY --from=build /app/apps/web/dist /usr/share/nginx/html

CMD ["/app/start-nginx.sh"]

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1:${PORT:-80}/health || exit 1
